/* ============================================================================
   DAISYOS ECOSYSTEM - COMPLETE DESIGN SYSTEM
   Dark Mode | Neon Theme | Racing-Inspired | Fully Customizable
   ============================================================================ */

/* --- CSS Custom Properties (Overrideable via Settings) --- */
:root {
    /* Primary accent - defaults to Neon Cyan */
    --accent-primary: #00f0ff;
    --accent-secondary: #ff006e;
    --accent-tertiary: #39ff14;
    
    /* Backgrounds */
    --bg-deep: #0a0e27;
    --bg-mid: #0f1535;
    --bg-elevated: #151b3a;
    --bg-surface: #1a2547;
    
    /* Text */
    --text-primary: #e0f7ff;
    --text-secondary: #a0d8ff;
    --text-muted: #606080;
    
    /* Glows */
    --glow-primary: 0 0 20px rgba(0, 240, 255, 0.5), 0 0 40px rgba(0, 240, 255, 0.3);
    --glow-secondary: 0 0 20px rgba(255, 0, 110, 0.5), 0 0 40px rgba(255, 0, 110, 0.3);
    --glow-tertiary: 0 0 20px rgba(57, 255, 20, 0.5), 0 0 40px rgba(57, 255, 20, 0.3);
    
    /* Borders */
    --border-primary: 2px solid var(--accent-primary);
    --border-subtle: 1px solid rgba(0, 240, 255, 0.2);
    
    /* Typography */
    --font-display: 'Orbitron', 'Rajdhani', sans-serif;
    --font-heading: 'Audiowide', 'Rajdhani', sans-serif;
    --font-mono: 'JetBrains Mono', 'Space Mono', monospace;
    --font-body: 'IBM Plex Sans', 'Space Mono', sans-serif;
    --font-size-base: 16px;
    
    /* Spacing */
    --sidebar-width: 260px;
    --header-height: 0px;
    --footer-height: auto;
    
    /* Transitions */
    --transition-fast: 0.2s ease;
    --transition-normal: 0.3s ease;
    --transition-slow: 0.5s ease;
}

/* Theme: Light Mode */
[data-theme="light"] {
    --bg-deep: #f0f4ff;
    --bg-mid: #e8ecf8;
    --bg-elevated: #ffffff;
    --bg-surface: #f5f7fd;
    --text-primary: #0a0e27;
    --text-secondary: #1a2547;
    --text-muted: #606080;
}

/* Theme: High Contrast */
[data-high-contrast="true"] {
    --text-primary: #ffffff;
    --text-secondary: #e0e0e0;
    --text-muted: #b0b0b0;
    --bg-deep: #000000;
    --bg-mid: #0a0a0a;
    --bg-elevated: #111111;
    --bg-surface: #1a1a1a;
}

/* Theme: Color Blind Friendly */
[data-color-blind="true"] {
    --accent-primary: #0088ff;
    --accent-secondary: #ff6600;
    --accent-tertiary: #ffcc00;
}

/* --- Global Reset --- */
*, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
    font-size: var(--font-size-base);
}

body {
    font-family: var(--font-body);
    background: var(--bg-deep);
    color: var(--text-primary);
    line-height: 1.6;
    overflow-x: hidden;
    min-height: 100vh;
    position: relative;
    transition: background var(--transition-normal), color var(--transition-normal);
}

/* --- Floating Flags Canvas --- */
.flags-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    opacity: 0.3;
}

/* --- Settings Gear Button --- */
.settings-gear-btn {
    position: fixed;
    top: 20px;
    right: 80px;
    z-index: 1001;
    background: rgba(21, 27, 58, 0.9);
    border: var(--border-primary);
    color: var(--accent-primary);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--glow-primary);
    transition: all var(--transition-normal);
    backdrop-filter: blur(10px);
}
.settings-gear-btn:hover {
    transform: rotate(90deg);
    box-shadow: 0 0 30px var(--accent-primary);
    background: var(--accent-primary);
    color: var(--bg-deep);
}

/* --- Help Icon Button --- */
.help-icon-btn {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 1001;
    background: rgba(21, 27, 58, 0.9);
    border: var(--border-primary);
    color: var(--accent-primary);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--glow-primary);
    transition: all var(--transition-normal);
    backdrop-filter: blur(10px);
}
.help-icon-btn:hover {
    box-shadow: 0 0 30px var(--accent-primary);
    background: var(--accent-primary);
    color: var(--bg-deep);
}

/* --- Settings Panel --- */
.settings-panel {
    position: fixed;
    top: 0;
    right: 0;
    width: 400px;
    max-width: 90vw;
    height: 100vh;
    background: var(--bg-elevated);
    border-left: var(--border-primary);
    z-index: 2000;
    box-shadow: -10px 0 40px rgba(0,0,0,0.5);
    overflow-y: auto;
    transition: transform var(--transition-normal);
    transform: translateX(0);
}
.settings-panel.hidden {
    transform: translateX(100%);
}
.settings-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px;
    border-bottom: var(--border-subtle);
    background: var(--bg-surface);
}
.settings-panel-header h2 {
    font-family: var(--font-display);
    font-size: 20px;
    color: var(--accent-primary);
}
.close-btn {
    background: none;
    border: none;
    color: var(--text-primary);
    font-size: 28px;
    cursor: pointer;
    transition: color var(--transition-fast);
}
.close-btn:hover {
    color: var(--accent-secondary);
}
.settings-panel-body {
    padding: 20px;
}
.settings-section {
    margin-bottom: 25px;
    padding-bottom: 20px;
    border-bottom: var(--border-subtle);
}
.settings-section h3 {
    font-family: var(--font-heading);
    font-size: 14px;
    color: var(--accent-primary);
    margin-bottom: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
}
.color-presets {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 15px;
}
.color-preset {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 3px solid transparent;
    cursor: pointer;
    transition: all var(--transition-fast);
}
.color-preset.active {
    border-color: #fff;
    box-shadow: 0 0 15px currentColor;
}
.color-preset:hover {
    transform: scale(1.2);
}
.settings-section label {
    display: block;
    color: var(--text-secondary);
    font-size: 13px;
    margin: 8px 0;
    cursor: pointer;
}
.settings-section select,
.settings-section input[type="text"],
.settings-section input[type="color"] {
    width: 100%;
    padding: 10px;
    background: var(--bg-deep);
    border: var(--border-subtle);
    color: var(--text-primary);
    border-radius: 5px;
    font-family: var(--font-body);
    margin-top: 5px;
}
.settings-section input[type="range"] {
    width: calc(100% - 60px);
    display: inline-block;
}
#fontSizeValue {
    display: inline-block;
    width: 50px;
    text-align: center;
    color: var(--accent-primary);
    font-family: var(--font-mono);
}

/* --- Help Panel --- */
.help-panel {
    position: fixed;
    top: 0;
    right: 0;
    width: 400px;
    max-width: 90vw;
    height: 100vh;
    background: var(--bg-elevated);
    border-left: var(--border-primary);
    z-index: 2000;
    box-shadow: -10px 0 40px rgba(0,0,0,0.5);
    overflow-y: auto;
    transition: transform var(--transition-normal);
    transform: translateX(0);
}
.help-panel.hidden {
    transform: translateX(100%);
}
.help-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px;
    border-bottom: var(--border-subtle);
    background: var(--bg-surface);
}
.help-panel-header h2 {
    font-family: var(--font-display);
    font-size: 20px;
    color: var(--accent-tertiary);
}
.help-panel-body {
    padding: 20px;
}
.help-panel-body textarea {
    width: 100%;
    height: 120px;
    background: var(--bg-deep);
    border: var(--border-subtle);
    color: var(--text-primary);
    padding: 12px;
    border-radius: 8px;
    font-family: var(--font-body);
    resize: vertical;
    margin-bottom: 15px;
}
.help-faq {
    margin-top: 25px;
}
.help-faq h3 {
    font-family: var(--font-heading);
    color: var(--accent-tertiary);
    margin-bottom: 12px;
}
.help-faq details {
    margin-bottom: 10px;
    padding: 10px;
    background: var(--bg-surface);
    border-radius: 5px;
    cursor: pointer;
}
.help-faq summary {
    color: var(--text-primary);
    font-weight: 600;
}
.help-faq p {
    color: var(--text-secondary);
    margin-top: 8px;
    font-size: 13px;
}

/* --- App Shell --- */
.app-shell {
    display: flex;
    min-height: 100vh;
    position: relative;
    z-index: 1;
}

/* --- Sidebar Navigation --- */
.sidebar-nav {
    width: var(--sidebar-width);
    background: linear-gradient(180deg, var(--bg-mid) 0%, var(--bg-elevated) 100%);
    border-right: var(--border-primary);
    padding: 20px 0;
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    z-index: 100;
    box-shadow: var(--glow-primary);
    overflow-y: auto;
}
.sidebar-brand {
    padding: 20px 25px;
    border-bottom: var(--border-subtle);
    margin-bottom: 20px;
}
.brand-logo {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 900;
    letter-spacing: 3px;
    color: var(--text-primary);
}
.brand-logo .accent {
    color: var(--accent-primary);
    text-shadow: var(--glow-primary);
}
.brand-tagline {
    font-family: var(--font-heading);
    font-size: 10px;
    color: var(--accent-secondary);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 5px;
}
.sidebar-menu {
    list-style: none;
    flex: 1;
}
.sidebar-menu li {
    margin: 2px 0;
}
.nav-btn {
    width: 100%;
    padding: 14px 25px;
    background: transparent;
    border: none;
    color: var(--text-secondary);
    text-align: left;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 14px;
    transition: all var(--transition-fast);
    position: relative;
    display: flex;
    align-items: center;
    gap: 10px;
}
.nav-btn:hover {
    background: rgba(0, 240, 255, 0.05);
    color: var(--text-primary);
}
.nav-btn.active {
    background: rgba(0, 240, 255, 0.1);
    color: var(--accent-primary);
    border-right: 3px solid var(--accent-primary);
    box-shadow: inset 0 0 20px rgba(0, 240, 255, 0.1);
}
.nav-divider {
    border: none;
    border-top: var(--border-subtle);
    margin: 15px 25px;
}
.sidebar-footer {
    padding: 20px 25px;
    border-top: var(--border-subtle);
    text-align: center;
}
.sidebar-footer p {
    font-size: 10px;
    color: var(--text-muted);
    margin: 5px 0;
    letter-spacing: 1px;
}

/* --- Main Content --- */
.main-content {
    flex: 1;
    margin-left: var(--sidebar-width);
    padding: 30px